# Variables leídas por supabase/config.toml vía env(...) al correr `supabase start`.
# El CLI de Supabase NO carga este archivo automáticamente: hay que exportarlas antes,
# por ejemplo: export $(grep -v '^#' .env | xargs) && supabase start

# Auth por teléfono (SMS OTP) — provider Twilio
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=

# Login social — Google
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Login social — Facebook
SUPABASE_AUTH_EXTERNAL_FACEBOOK_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_FACEBOOK_SECRET=

# Login social — Apple
SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=
