{
  "name": "kipo-platform",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:dashboard": "pnpm --filter kipo-dashboard-ui dev",
    "dev:landing": "pnpm --filter Kipo-landing dev",
    "dev:api": "pnpm --filter kipo-api dev",
    "build": "pnpm build:packages && pnpm --parallel --filter './src/apps/**' build",
    "build:dashboard": "pnpm build:packages && pnpm --filter kipo-dashboard build",
    "build:landing": "pnpm build:packages && pnpm --filter Kipo-landing build",
    "build:packages": "pnpm --filter @kipo/ui-react build",
    "storybook": "pnpm --filter @kipo/ui-react storybook",
    "lint": "pnpm -r --parallel lint",
    "typecheck": "pnpm -r --parallel typecheck",
    "install:py": "pnpm --filter kipo-api sync",
    "prepare": "husky",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config e2e/playwright.config.ts --headed --workers=1",
    "test:e2e:ui": "playwright test --config e2e/playwright.config.ts --ui"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "22.10.5",
    "@typescript-eslint/parser": "8.62.0",
    "astro-eslint-parser": "2.0.0",
    "eslint": "10.5.0",
    "eslint-plugin-astro": "2.0.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "playwright": "1.61.1",
    "typescript": "5.4.5"
  }
}
