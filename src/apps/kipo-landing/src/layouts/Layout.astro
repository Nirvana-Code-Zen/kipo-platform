---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const { title, description = 'Kipo — Factura. Sin drama. CFDI 4.0 para freelancers y pequeños negocios en México.' } = Astro.props
---

<!doctype html>
<html lang="es" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f8f6f5" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/kipo-logo@1x.png" />
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
