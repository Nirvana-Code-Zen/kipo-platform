---
import {Image} from 'astro:assets'
import kipoLogo from '../assets/kipo-slogan/kipo-logo.svg'

const year = new Date().getFullYear()
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">

      <div class="footer-brand">
        <a href="/" class="footer-logo-link" aria-label="Kipo inicio">
          <Image src={kipoLogo} alt="Kipo Logo" class="h-auto w-[10rem]" aria-hidden="true" />
        </a>
        <p class="footer-tagline">
          Factura. Sin drama.<br/>
          CFDI 4.0 para freelancers y<br/>pequeños negocios en México.
        </p>
      </div>

      <div>
        <p class="footer-col-label">Producto</p>
        <nav class="footer-nav" aria-label="Links del producto">
          <a href="/#como-funciona" class="footer-link">Cómo funciona</a>
          <a href="/precios" class="footer-link">Precios</a>
        </nav>
      </div>

      <div>
        <p class="footer-col-label">Legal</p>
        <nav class="footer-nav" aria-label="Links legales">
          <a href="/terminos" class="footer-link">Términos de uso</a>
          <a href="/privacidad" class="footer-link">Aviso de privacidad</a>
        </nav>
      </div>

    </div>

    <div class="footer-bottom">
      <span class="footer-copy">© {year} Kipo. Todos los derechos reservados.</span>
      <div class="footer-cert">
        <span>Timbrado certificado SAT</span>
        <span aria-hidden="true">·</span>
        <a
          href="https://www.facturapi.io"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-cert-link"
        >FacturAPI</a>
        <span aria-hidden="true">·</span>
        <span>CFDI 4.0</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 13rem;
    background: var(--bg-base);
  }

  .footer-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem 0 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 1.5rem 2rem;
    margin-bottom: 1.5rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-logo-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .footer-logo-img {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .footer-logo-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--kipo-red);
  }

  .footer-tagline {
    font-family: var(--font-body);
    font-size: 0.78rem;
    line-height: 1.6;
    color: var(--text-muted);
    margin: 0;
  }

  .footer-col-label {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin: 0 0 0.75rem;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-link {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--text-body);
    text-decoration: none;
    transition: color 150ms;
  }

  .footer-link:hover {
    color: var(--text-strong);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 1rem 0;
    border-top: 1px solid var(--border-subtle);
  }

  .footer-copy {
    font-family: var(--font-body);
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .footer-cert {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .footer-cert-link {
    font-weight: 600;
    color: var(--text-body);
    text-decoration: none;
    transition: color 150ms;
  }

  .footer-cert-link:hover {
    color: var(--text-strong);
  }

  @media (max-width: 640px) {
    .site-footer {
      padding: 0 1rem;
    }
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
