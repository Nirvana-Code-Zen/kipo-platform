---
// Smartphone mostrando factura CFDI timbrada
---

<svg
  viewBox="0 0 340 320"
  width="100%"
  
  xmlns="http://www.w3.org/2000/svg"
  aria-labelledby="invoice-illus-title"
  role="img"
>
  <title id="invoice-illus-title">Teléfono mostrando factura CFDI timbrada</title>

  <defs>
    <filter id="phone-shadow" x="-30%" y="-20%" width="160%" height="140%">
      <feDropShadow dx="0" dy="8" stdDeviation="14" flood-color="#032641" flood-opacity="0.16"/>
    </filter>
    <radialGradient id="bg-lime-blob" cx="55%" cy="48%" r="45%">
      <stop offset="0%" stop-color="#C6F542" stop-opacity="0.18"/>
      <stop offset="100%" stop-color="#C6F542" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="red-bg" cx="30%" cy="70%" r="35%">
      <stop offset="0%" stop-color="#e00b26" stop-opacity="0.07"/>
      <stop offset="100%" stop-color="#e00b26" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <!-- Background blobs -->
  <ellipse cx="195" cy="155" rx="130" ry="120" fill="url(#bg-lime-blob)"/>
  <ellipse cx="80" cy="230" rx="90" ry="70" fill="url(#red-bg)"/>

  <!-- === HAND === -->
  <!-- Palm -->
  <rect x="130" y="252" width="80" height="52" rx="22" fill="#D4935C"/>
  <!-- Palm shadow top -->
  <rect x="130" y="252" width="80" height="12" rx="10" fill="#C8854A" fill-opacity="0.4"/>
  <!-- Thumb -->
  <path d="M130 268 Q112 262 108 248 Q106 238 116 236 Q126 234 130 250z" fill="#D4935C"/>
  <!-- Thumb crease -->
  <path d="M116 244 Q118 252 124 258" stroke="#C8854A" stroke-width="1.5" fill="none" stroke-linecap="round" opacity="0.5"/>
  <!-- Finger bumps (top of palm) -->
  <rect x="140" y="248" width="14" height="8" rx="7" fill="#D4935C"/>
  <rect x="158" y="246" width="14" height="8" rx="7" fill="#D4935C"/>
  <rect x="176" y="247" width="14" height="8" rx="7" fill="#D4935C"/>
  <rect x="194" y="250" width="12" height="8" rx="6" fill="#D4935C"/>
  <!-- Knuckle lines -->
  <line x1="147" y1="248" x2="147" y2="254" stroke="#C8854A" stroke-width="1" opacity="0.4"/>
  <line x1="165" y1="247" x2="165" y2="252" stroke="#C8854A" stroke-width="1" opacity="0.4"/>
  <line x1="183" y1="248" x2="183" y2="253" stroke="#C8854A" stroke-width="1" opacity="0.4"/>

  <!-- === PHONE BODY === -->
  <rect x="118" y="52" width="104" height="208" rx="20" fill="#032641" filter="url(#phone-shadow)"/>
  <!-- Phone side highlight left -->
  <rect x="118" y="72" width="3" height="80" rx="1.5" fill="#032641" fill-opacity="0.6"/>
  <!-- Phone side highlight right -->
  <rect x="219" y="72" width="3" height="80" rx="1.5" fill="#0F1720" fill-opacity="0.8"/>
  <!-- Volume buttons -->
  <rect x="115" y="100" width="4" height="18" rx="2" fill="#032641"/>
  <rect x="115" y="124" width="4" height="18" rx="2" fill="#032641"/>
  <!-- Power button -->
  <rect x="221" y="112" width="4" height="24" rx="2" fill="#032641"/>

  <!-- Phone notch pill -->
  <rect x="152" y="60" width="36" height="8" rx="4" fill="#0F1720"/>

  <!-- === PHONE SCREEN === -->
  <rect x="124" y="68" width="92" height="184" rx="14" fill="#F8FAFC"/>

  <!-- Status bar -->
  <rect x="124" y="68" width="92" height="16" rx="14" fill="#F8FAFC"/>
  <!-- Time indicator -->
  <rect x="130" y="73" width="20" height="5" rx="2" fill="#4C6075" fill-opacity="0.5"/>
  <!-- Battery -->
  <rect x="202" y="73" width="10" height="5" rx="1.5" fill="#4C6075" fill-opacity="0.4"/>
  <rect x="213" y="74.5" width="2" height="2" rx="1" fill="#4C6075" fill-opacity="0.4"/>
  <!-- Signal dots -->
  <circle cx="196" cy="75.5" r="1.5" fill="#4C6075" fill-opacity="0.4"/>
  <circle cx="192" cy="75.5" r="1.5" fill="#4C6075" fill-opacity="0.4"/>

  <!-- App header bar -->
  <rect x="124" y="84" width="92" height="26" rx="0" fill="#e00b26"/>
  <!-- Header: "Kipo" wordmark area (simplified K mark) -->
  <rect x="130" y="91" width="14" height="12" rx="3" fill="white" fill-opacity="0.9"/>
  <path d="M133 93l5 4-5 4" stroke="#e00b26" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  <!-- Header: title text placeholder -->
  <rect x="150" y="93" width="36" height="5" rx="2" fill="white" fill-opacity="0.7"/>
  <rect x="150" y="100" width="24" height="4" rx="2" fill="white" fill-opacity="0.4"/>
  <!-- Header right: share icon -->
  <circle cx="207" cy="97" r="6" fill="white" fill-opacity="0.2"/>
  <path d="M204 97h6M207 94v6" stroke="white" stroke-width="1.5" stroke-linecap="round" fill="none"/>

  <!-- === INVOICE CONTENT === -->

  <!-- Section: CFDI header -->
  <rect x="130" y="116" width="80" height="5" rx="2" fill="#2C1810" fill-opacity="0.7"/>
  <rect x="130" y="123" width="50" height="4" rx="2" fill="#A99E8C"/>

  <!-- Divider -->
  <rect x="128" y="132" width="84" height="1" rx="0.5" fill="#E4D9C9"/>

  <!-- Client info block -->
  <rect x="130" y="136" width="30" height="4" rx="2" fill="#A99E8C"/>
  <rect x="130" y="142" width="72" height="5" rx="2" fill="#2C1810" fill-opacity="0.6"/>
  <rect x="130" y="149" width="58" height="4" rx="2" fill="#A99E8C"/>

  <!-- Divider -->
  <rect x="128" y="158" width="84" height="1" rx="0.5" fill="#E4D9C9"/>

  <!-- Amount section — mono style -->
  <rect x="130" y="162" width="30" height="4" rx="2" fill="#A99E8C"/>
  <!-- Amount value: larger, monospaced look -->
  <rect x="130" y="169" width="18" height="7" rx="2" fill="#2C1810" fill-opacity="0.8"/>
  <rect x="152" y="169" width="52" height="7" rx="2" fill="#e00b26" fill-opacity="0.9"/>
  <!-- IVA row -->
  <rect x="130" y="180" width="25" height="4" rx="2" fill="#A99E8C"/>
  <rect x="180" y="180" width="24" height="4" rx="2" fill="#A99E8C"/>
  <!-- Total row -->
  <rect x="130" y="188" width="20" height="5" rx="2" fill="#2C1810" fill-opacity="0.7"/>
  <rect x="174" y="188" width="30" height="5" rx="2" fill="#2C1810" fill-opacity="0.7"/>

  <!-- Divider -->
  <rect x="128" y="198" width="84" height="1" rx="0.5" fill="#E4D9C9"/>

  <!-- Timbrada badge -->
  <rect x="128" y="203" width="84" height="22" rx="8" fill="#DCFCE7"/>
  <circle cx="142" cy="214" r="7" fill="#16A34A"/>
  <path d="M138.5 214l2.5 2.5 4.5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  <rect x="153" y="210" width="38" height="5" rx="2" fill="#16A34A" fill-opacity="0.8"/>
  <rect x="153" y="217" width="28" height="4" rx="2" fill="#16A34A" fill-opacity="0.5"/>

  <!-- Folio line -->
  <rect x="130" y="232" width="22" height="4" rx="2" fill="#A99E8C"/>
  <rect x="156" y="232" width="42" height="4" rx="2" fill="#4C6075" fill-opacity="0.6"/>

  <!-- Bottom CTA button on screen -->
  <rect x="128" y="240" width="84" height="18" rx="7" fill="#e00b26"/>
  <rect x="144" y="246" width="52" height="5" rx="2" fill="white" fill-opacity="0.85"/>

  <!-- === FLOATING ELEMENTS === -->

  <!-- Lightning bolt top-right -->
  <g transform="translate(244, 55)">
    <polygon points="14,0 8,16 14,14 6,32 18,12 12,14" fill="#C6F542"/>
    <polygon points="14,0 8,16 14,14 6,32 18,12 12,14" fill="none" stroke="#A9D92B" stroke-width="0.5"/>
  </g>

  <!-- Speed lines from phone -->
  <line x1="96" y1="130" x2="82" y2="130" stroke="#C6F542" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
  <line x1="92" y1="142" x2="74" y2="142" stroke="#C6F542" stroke-width="2" stroke-linecap="round" opacity="0.35"/>
  <line x1="96" y1="154" x2="78" y2="154" stroke="#C6F542" stroke-width="2" stroke-linecap="round" opacity="0.2"/>

  <!-- SAT stamp decoration -->
  <circle cx="54" cy="82" r="24" fill="none" stroke="#e00b26" stroke-width="1.5" stroke-dasharray="3 3" opacity="0.3"/>
  <circle cx="54" cy="82" r="16" fill="#e00b26" fill-opacity="0.06"/>
  <rect x="46" y="78" width="16" height="8" rx="2" fill="#e00b26" fill-opacity="0.35"/>
  <rect x="48" y="82" width="12" height="3" rx="1" fill="#e00b26" fill-opacity="0.25"/>

  <!-- Small decorative dots -->
  <circle cx="290" cy="180" r="4" fill="#C6F542" fill-opacity="0.4"/>
  <circle cx="300" cy="192" r="2.5" fill="#C6F542" fill-opacity="0.25"/>
  <circle cx="284" cy="194" r="2" fill="#C6F542" fill-opacity="0.2"/>

</svg>
