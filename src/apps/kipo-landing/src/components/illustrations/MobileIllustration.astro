---
// App móvil Kipo mostrando lista de facturas CFDI
---

<svg
  viewBox="0 0 260 360"
  width="100%"

  xmlns="http://www.w3.org/2000/svg"
  aria-labelledby="mobile-illus-title"
  role="img"
>
  <title id="mobile-illus-title">App móvil de Kipo mostrando lista de facturas CFDI</title>

  <defs>
    <radialGradient id="red-glow-bg" cx="50%" cy="60%" r="50%">
      <stop offset="0%" stop-color="#e00b26" stop-opacity="0.10"/>
      <stop offset="100%" stop-color="#e00b26" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="lime-glow-bg" cx="50%" cy="20%" r="40%">
      <stop offset="0%" stop-color="#C6F542" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="#C6F542" stop-opacity="0"/>
    </radialGradient>
    <filter id="phone-float" x="-25%" y="-15%" width="150%" height="130%">
      <feDropShadow dx="0" dy="12" stdDeviation="18" flood-color="#032641" flood-opacity="0.18"/>
      <feDropShadow dx="0" dy="4" stdDeviation="6" flood-color="#e00b26" flood-opacity="0.08"/>
    </filter>
    <filter id="badge-drop" x="-30%" y="-30%" width="160%" height="160%">
      <feDropShadow dx="0" dy="2" stdDeviation="4" flood-color="#032641" flood-opacity="0.12"/>
    </filter>
    <filter id="kipo-badge-shadow" x="-40%" y="-40%" width="180%" height="180%">
      <feDropShadow dx="0" dy="1" stdDeviation="2.5" flood-color="#032641" flood-opacity="0.15"/>
    </filter>
    <clipPath id="screen-clip">
      <rect x="76" y="44" width="108" height="268" rx="18"/>
    </clipPath>
  </defs>

  <style>
    @keyframes mob-badge-float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }
    @keyframes mob-item-in {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes mob-dot-pulse {
      0%, 100% { opacity: 1; r: 5; }
      50% { opacity: 0.6; r: 4; }
    }
    @keyframes mob-cta-pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.82; }
    }

    #mob-cfdi-badge {
      animation: mob-badge-float 4s ease-in-out infinite;
      animation-delay: -2s;
    }
    #mob-item-1 {
      animation: mob-item-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-delay: 0.2s;
    }
    #mob-item-2 {
      animation: mob-item-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-delay: 0.32s;
    }
    #mob-item-3 {
      animation: mob-item-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-delay: 0.44s;
    }
    #mob-dot-1, #mob-dot-3 {
      animation: mob-dot-pulse 2.2s ease-in-out infinite;
    }
    #mob-dot-2 {
      animation: mob-dot-pulse 2.8s ease-in-out infinite;
      animation-delay: -1s;
    }
    #mob-cta {
      animation: mob-cta-pulse 2.5s ease-in-out infinite;
      animation-delay: 0.8s;
    }

    @media (prefers-reduced-motion: reduce) {
      #mob-cfdi-badge, #mob-item-1, #mob-item-2, #mob-item-3,
      #mob-dot-1, #mob-dot-2, #mob-dot-3, #mob-cta {
        animation: none;
        opacity: 1;
        transform: none;
      }
    }
  </style>


  <!-- Background glows -->
  <ellipse cx="130" cy="216" rx="130" ry="120" fill="url(#red-glow-bg)"/>
  <ellipse cx="130" cy="80" rx="100" ry="80" fill="url(#lime-glow-bg)"/>

  <!-- Phone shadow on surface -->
  <ellipse cx="130" cy="336" rx="58" ry="10" fill="#032641" fill-opacity="0.10"/>

  <!-- === PHONE BODY === -->
  <rect x="70" y="28" width="120" height="296" rx="26" fill="#032641" filter="url(#phone-float)"/>

  <!-- Phone rim highlight (left edge) -->
  <rect x="70" y="50" width="2.5" height="120" rx="1" fill="#032641"/>
  <!-- Phone rim shadow (right edge) -->
  <rect x="187.5" y="50" width="2.5" height="120" rx="1" fill="#0F1720"/>

  <!-- Physical buttons left: volume -->
  <rect x="67" y="90" width="4" height="22" rx="2" fill="#032641"/>
  <rect x="67" y="118" width="4" height="22" rx="2" fill="#032641"/>
  <!-- Physical button right: power -->
  <rect x="189" y="104" width="4" height="30" rx="2" fill="#032641"/>

  <!-- Notch pill -->
  <rect x="108" y="36" width="44" height="10" rx="5" fill="#0F1720"/>

  <!-- Camera dot in notch -->
  <circle cx="145" cy="41" r="3" fill="#0A1018"/>
  <circle cx="145" cy="41" r="1.5" fill="#1A2530" fill-opacity="0.5"/>

  <!-- === PHONE SCREEN === -->
  <rect x="76" y="44" width="108" height="268" rx="18" fill="#F8FAFC"/>

  <!-- Status bar -->
  <rect x="76" y="44" width="108" height="20" rx="18" fill="#F8FAFC"/>
  <!-- Time text placeholder -->
  <rect x="84" y="50" width="22" height="6" rx="3" fill="#4C6075" fill-opacity="0.45"/>
  <!-- Status icons right -->
  <!-- Signal bars -->
  <rect x="162" y="52" width="2" height="4" rx="1" fill="#4C6075" fill-opacity="0.35"/>
  <rect x="166" y="50" width="2" height="6" rx="1" fill="#4C6075" fill-opacity="0.45"/>
  <rect x="170" y="48" width="2" height="8" rx="1" fill="#4C6075" fill-opacity="0.6"/>
  <!-- Battery -->
  <rect x="174" y="50" width="8" height="5" rx="1.5" fill="#4C6075" fill-opacity="0.4"/>
  <rect x="182" y="51.5" width="1.5" height="2" rx="0.8" fill="#4C6075" fill-opacity="0.4"/>
  <rect x="175" y="51" width="5" height="3" rx="0.8" fill="#16A34A" fill-opacity="0.7"/>

  <!-- === APP HEADER === -->
  <rect x="76" y="64" width="108" height="52" rx="0" fill="#FFFFFF"/>
  <!-- Bottom border of header -->
  <rect x="76" y="115" width="108" height="1" fill="#E4D9C9"/>

  <!-- Kipo logo mark (inline) -->
  <rect x="84" y="72" width="28" height="28" rx="8" fill="white"/>
  <svg x="84" y="72" width="28" height="28" viewBox="348 265 368 368">
