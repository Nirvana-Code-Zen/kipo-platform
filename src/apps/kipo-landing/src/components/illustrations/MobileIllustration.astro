---
// App móvil Kipo mostrando lista de facturas CFDI
---

<svg
  viewBox="0 0 260 360"
  width="100%"
  
  xmlns="http://www.w3.org/2000/svg"
  aria-labelledby="mobile-illus-title"
  role="img"
>
  <title id="mobile-illus-title">App móvil de Kipo mostrando lista de facturas CFDI</title>

  <defs>
    <radialGradient id="red-glow-bg" cx="50%" cy="60%" r="50%">
      <stop offset="0%" stop-color="#e00b26" stop-opacity="0.10"/>
      <stop offset="100%" stop-color="#e00b26" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="lime-glow-bg" cx="50%" cy="20%" r="40%">
      <stop offset="0%" stop-color="#C6F542" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="#C6F542" stop-opacity="0"/>
    </radialGradient>
    <filter id="phone-float" x="-25%" y="-15%" width="150%" height="130%">
      <feDropShadow dx="0" dy="12" stdDeviation="18" flood-color="#032641" flood-opacity="0.18"/>
      <feDropShadow dx="0" dy="4" stdDeviation="6" flood-color="#e00b26" flood-opacity="0.08"/>
    </filter>
    <filter id="badge-drop" x="-30%" y="-30%" width="160%" height="160%">
      <feDropShadow dx="0" dy="2" stdDeviation="4" flood-color="#032641" flood-opacity="0.12"/>
    </filter>
    <clipPath id="screen-clip">
      <rect x="76" y="44" width="108" height="268" rx="18"/>
    </clipPath>
  </defs>

  <!-- Background glows -->
  <ellipse cx="130" cy="216" rx="130" ry="120" fill="url(#red-glow-bg)"/>
  <ellipse cx="130" cy="80" rx="100" ry="80" fill="url(#lime-glow-bg)"/>

  <!-- Phone shadow on surface -->
  <ellipse cx="130" cy="336" rx="58" ry="10" fill="#032641" fill-opacity="0.10"/>

  <!-- === PHONE BODY === -->
  <rect x="70" y="28" width="120" height="296" rx="26" fill="#032641" filter="url(#phone-float)"/>

  <!-- Phone rim highlight (left edge) -->
  <rect x="70" y="50" width="2.5" height="120" rx="1" fill="#032641"/>
  <!-- Phone rim shadow (right edge) -->
  <rect x="187.5" y="50" width="2.5" height="120" rx="1" fill="#0F1720"/>

  <!-- Physical buttons left: volume -->
  <rect x="67" y="90" width="4" height="22" rx="2" fill="#032641"/>
  <rect x="67" y="118" width="4" height="22" rx="2" fill="#032641"/>
  <!-- Physical button right: power -->
  <rect x="189" y="104" width="4" height="30" rx="2" fill="#032641"/>

  <!-- Notch pill -->
  <rect x="108" y="36" width="44" height="10" rx="5" fill="#0F1720"/>

  <!-- Camera dot in notch -->
  <circle cx="145" cy="41" r="3" fill="#0A1018"/>
  <circle cx="145" cy="41" r="1.5" fill="#1A2530" fill-opacity="0.5"/>

  <!-- === PHONE SCREEN === -->
  <rect x="76" y="44" width="108" height="268" rx="18" fill="#F8FAFC"/>

  <!-- Status bar -->
  <rect x="76" y="44" width="108" height="20" rx="18" fill="#F8FAFC"/>
  <!-- Time text placeholder -->
  <rect x="84" y="50" width="22" height="6" rx="3" fill="#4C6075" fill-opacity="0.45"/>
  <!-- Status icons right -->
  <!-- Signal bars -->
  <rect x="162" y="52" width="2" height="4" rx="1" fill="#4C6075" fill-opacity="0.35"/>
  <rect x="166" y="50" width="2" height="6" rx="1" fill="#4C6075" fill-opacity="0.45"/>
  <rect x="170" y="48" width="2" height="8" rx="1" fill="#4C6075" fill-opacity="0.6"/>
  <!-- Battery -->
  <rect x="174" y="50" width="8" height="5" rx="1.5" fill="#4C6075" fill-opacity="0.4"/>
  <rect x="182" y="51.5" width="1.5" height="2" rx="0.8" fill="#4C6075" fill-opacity="0.4"/>
  <rect x="175" y="51" width="5" height="3" rx="0.8" fill="#16A34A" fill-opacity="0.7"/>

  <!-- === APP HEADER === -->
  <rect x="76" y="64" width="108" height="52" rx="0" fill="#FFFFFF"/>
  <!-- Bottom border of header -->
  <rect x="76" y="115" width="108" height="1" fill="#E4D9C9"/>

  <!-- Kipo logo mark -->
  <clipPath id="mob-logo-clip"><rect x="84" y="72" width="28" height="28" rx="8"/></clipPath>
  <image href="/kipo-logo.svg" x="84" y="72" width="28" height="28" clip-path="url(#mob-logo-clip)"/>

  <!-- "Kipo" wordmark -->
  <rect x="118" y="76" width="26" height="7" rx="3" fill="#032641" fill-opacity="0.75"/>
  <rect x="118" y="86" width="40" height="5" rx="2" fill="#A99E8C"/>

  <!-- Avatar top right -->
  <circle cx="172" cy="86" r="13" fill="#f8f6f5"/>
  <circle cx="172" cy="83" r="6" fill="#D4935C"/>
  <ellipse cx="172" cy="96" rx="9" ry="6" fill="#D4935C"/>

  <!-- Greeting -->
  <rect x="84" y="101" width="60" height="5" rx="2" fill="#A99E8C"/>
  <rect x="84" y="108" width="80" height="5" rx="2" fill="#032641" fill-opacity="0.55"/>

  <!-- === BALANCE CARD === -->
  <rect x="82" y="122" width="96" height="50" rx="12" fill="#e00b26"/>
  <!-- Card gradient depth (right side darker) -->
  <rect x="148" y="122" width="30" height="50" rx="12" fill="#bc0921" fill-opacity="0.6"/>
  <!-- Card top label -->
  <rect x="90" y="130" width="38" height="4" rx="2" fill="white" fill-opacity="0.55"/>
  <!-- Card amount -->
  <rect x="90" y="138" width="18" height="6" rx="2" fill="white" fill-opacity="0.7"/>
  <rect x="111" y="138" width="46" height="6" rx="2" fill="white" fill-opacity="0.9"/>
  <!-- Timbres badge -->
  <rect x="90" y="150" width="48" height="13" rx="6" fill="white" fill-opacity="0.18"/>
  <rect x="96" y="154" width="36" height="5" rx="2" fill="white" fill-opacity="0.75"/>
  <!-- Card decorative circles -->
  <circle cx="156" cy="136" r="18" fill="white" fill-opacity="0.06"/>
  <circle cx="162" cy="150" r="12" fill="white" fill-opacity="0.05"/>

  <!-- === SECTION LABEL === -->
  <rect x="84" y="180" width="42" height="5" rx="2" fill="#032641" fill-opacity="0.65"/>
  <rect x="148" y="180" width="30" height="5" rx="2" fill="#e00b26" fill-opacity="0.5"/>

  <!-- === INVOICE LIST ITEMS === -->

  <!-- Item 1: Timbrada (green) -->
  <rect x="82" y="192" width="96" height="30" rx="8" fill="white"/>
  <rect x="82" y="192" width="96" height="30" rx="8" fill="none" stroke="#E4D9C9" stroke-width="1"/>
  <!-- Status dot green -->
  <circle cx="93" cy="207" r="5" fill="#16A34A"/>
  <!-- Client name -->
  <rect x="104" y="198" width="50" height="5" rx="2" fill="#032641" fill-opacity="0.7"/>
  <!-- Amount mono -->
  <rect x="104" y="206" width="36" height="4" rx="2" fill="#A99E8C"/>
  <!-- Timestamp right -->
  <rect x="154" y="200" width="18" height="4" rx="2" fill="#A99E8C" fill-opacity="0.6"/>
  <!-- Arrow right -->
  <path d="M168 207l4-3-4-3" stroke="#C8BCA8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>

  <!-- Item 2: Pendiente (amber) -->
  <rect x="82" y="227" width="96" height="30" rx="8" fill="white"/>
  <rect x="82" y="227" width="96" height="30" rx="8" fill="none" stroke="#E4D9C9" stroke-width="1"/>
  <!-- Status dot amber -->
  <circle cx="93" cy="242" r="5" fill="#CA8A04"/>
  <!-- Client name -->
  <rect x="104" y="233" width="44" height="5" rx="2" fill="#032641" fill-opacity="0.7"/>
  <!-- Amount -->
  <rect x="104" y="241" width="32" height="4" rx="2" fill="#A99E8C"/>
  <!-- Timestamp right -->
  <rect x="154" y="235" width="18" height="4" rx="2" fill="#A99E8C" fill-opacity="0.6"/>
  <!-- Arrow right -->
  <path d="M168 242l4-3-4-3" stroke="#C8BCA8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>

  <!-- Item 3: Timbrada (green) -->
  <rect x="82" y="262" width="96" height="30" rx="8" fill="white"/>
  <rect x="82" y="262" width="96" height="30" rx="8" fill="none" stroke="#E4D9C9" stroke-width="1"/>
  <!-- Status dot green -->
  <circle cx="93" cy="277" r="5" fill="#16A34A"/>
  <!-- Client name -->
  <rect x="104" y="268" width="56" height="5" rx="2" fill="#032641" fill-opacity="0.7"/>
  <!-- Amount -->
  <rect x="104" y="276" width="30" height="4" rx="2" fill="#A99E8C"/>
  <!-- Timestamp right -->
  <rect x="154" y="270" width="18" height="4" rx="2" fill="#A99E8C" fill-opacity="0.6"/>
  <!-- Arrow right -->
  <path d="M168 277l4-3-4-3" stroke="#C8BCA8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>

  <!-- === BOTTOM CTA BUTTON === -->
  <rect x="82" y="299" width="96" height="24" rx="10" fill="#C6F542"/>
  <!-- Button shadow/glow -->
  <rect x="82" y="299" width="96" height="24" rx="10" fill="none" stroke="#A9D92B" stroke-width="1"/>
  <!-- Lightning bolt icon -->
  <polygon points="127,305 123,314 127,312 122,322 131,311 127,313" fill="#032641" fill-opacity="0.7"/>
  <!-- Button text -->
  <rect x="133" y="307" width="36" height="5" rx="2" fill="#032641" fill-opacity="0.65"/>
  <rect x="137" y="314" width="28" height="4" rx="2" fill="#032641" fill-opacity="0.4"/>

  <!-- Screen bottom home indicator -->
  <rect x="108" y="330" width="44" height="4" rx="2" fill="#032641" fill-opacity="0.4"/>

  <!-- === FLOATING BADGE "✓ CFDI 4.0" === -->
  <g filter="url(#badge-drop)">
    <rect x="174" y="38" width="68" height="26" rx="13" fill="#C6F542"/>
    <!-- Checkmark -->
    <circle cx="188" cy="51" r="7" fill="#032641" fill-opacity="0.15"/>
    <path d="M184.5 51l2.5 2.5 4.5-5" stroke="#032641" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <!-- Text -->
    <rect x="196" y="47" width="38" height="5" rx="2" fill="#032641" fill-opacity="0.65"/>
    <rect x="199" y="54" width="32" height="4" rx="2" fill="#032641" fill-opacity="0.45"/>
  </g>

  <!-- Floating sparkles -->
  <g opacity="0.7">
    <path d="M46 90 L48 82 L50 90 L58 92 L50 94 L48 102 L46 94 L38 92z" fill="#e00b26" fill-opacity="0.3"/>
  </g>
  <circle cx="214" cy="180" r="5" fill="#C6F542" fill-opacity="0.45"/>
  <circle cx="224" cy="192" r="3" fill="#C6F542" fill-opacity="0.28"/>
  <circle cx="208" cy="196" r="2" fill="#C6F542" fill-opacity="0.2"/>

  <!-- Small decorative dots left side -->
  <circle cx="46" cy="160" r="3.5" fill="#C6F542" fill-opacity="0.3"/>
  <circle cx="54" cy="172" r="2" fill="#C6F542" fill-opacity="0.2"/>
  <circle cx="40" cy="174" r="2.5" fill="#e00b26" fill-opacity="0.15"/>

</svg>
