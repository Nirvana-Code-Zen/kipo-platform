  <path d="M330 175 Q348 192 352 216" stroke="#C6F542" stroke-width="16" stroke-linecap="round" fill="none"/>
  <!-- Right hand -->
  <ellipse cx="353" cy="220" rx="10" ry="8" fill="#F9C8A0"/>

  <!-- Neck -->
  <rect x="282" y="152" width="20" height="18" rx="9" fill="#F9C8A0"/>

  <!-- Head -->
  <ellipse cx="292" cy="136" rx="30" ry="32" fill="#F9C8A0"/>
  <!-- Ear left -->
  <ellipse cx="262" cy="136" rx="6" ry="8" fill="#F9C8A0"/>
  <!-- Ear right -->
  <ellipse cx="322" cy="136" rx="6" ry="8" fill="#F9C8A0"/>

  <!-- Client hair - wavy longer hair -->
  <ellipse cx="292" cy="112" rx="32" ry="18" fill="#4A2C1A"/>
  <path d="M262 128 Q262 106 292 104 Q322 106 322 128" fill="#4A2C1A"/>
  <!-- Hair sides flowing down -->
  <path d="M262 128 Q258 145 262 162" stroke="#4A2C1A" stroke-width="12" stroke-linecap="round" fill="none"/>
  <path d="M322 128 Q326 145 322 162" stroke="#4A2C1A" stroke-width="12" stroke-linecap="round" fill="none"/>
  <!-- Hair highlight -->
  <ellipse cx="280" cy="108" rx="12" ry="6" fill="#6B3E22" fill-opacity="0.5"/>

  <!-- Client face -->
  <!-- Eyebrows -->
  <path d="M280 128 Q284 125 288 127" stroke="#4A2C1A" stroke-width="1.8" stroke-linecap="round" fill="none"/>
  <path d="M296 127 Q300 125 304 128" stroke="#4A2C1A" stroke-width="1.8" stroke-linecap="round" fill="none"/>
  <!-- Eyes (slightly wide, looking at tablet with interest) -->
  <ellipse cx="284" cy="135" rx="5.5" ry="6" fill="#1A1A1A"/>
  <ellipse cx="300" cy="135" rx="5.5" ry="6" fill="#1A1A1A"/>
  <circle cx="286" cy="133" r="2" fill="white" fill-opacity="0.65"/>
  <circle cx="302" cy="133" r="2" fill="white" fill-opacity="0.65"/>
  <!-- Nose -->
  <ellipse cx="292" cy="143" rx="3" ry="2" fill="#E8A88A" fill-opacity="0.7"/>
  <!-- Open-mouth smile (impressed) -->
  <path d="M284 151 Q292 158 300 151" stroke="#C07040" stroke-width="2" fill="none" stroke-linecap="round"/>
  <ellipse cx="292" cy="153" rx="5" ry="3" fill="#E88080" fill-opacity="0.3"/>
  <!-- Cheek blush -->
  <ellipse cx="272" cy="141" rx="7" ry="4" fill="#F0A080" fill-opacity="0.22"/>
  <ellipse cx="312" cy="141" rx="7" ry="4" fill="#F0A080" fill-opacity="0.22"/>

  <!-- === SPEECH BUBBLE from client side === -->
  <g id="biz-bubble">
    <rect x="322" y="98" width="96" height="38" rx="12" fill="white" filter="url(#biz-drop)"/>
    <path d="M322 124 l-14 14 16-5z" fill="white"/>
    <rect x="322" y="98" width="96" height="38" rx="12" fill="none" stroke="#DCFCE7" stroke-width="1.5"/>
    <rect x="333" y="108" width="74" height="5" rx="2" fill="#032641" fill-opacity="0.5"/>
    <rect x="333" y="116" width="55" height="5" rx="2" fill="#16A34A" fill-opacity="0.7"/>
    <rect x="333" y="124" width="42" height="4" rx="2" fill="#A99E8C"/>
  </g>

  <!-- Floating lime decorations -->
  <circle id="biz-sparkle-1" cx="58" cy="104" r="5" fill="#C6F542" fill-opacity="0.4"/>
  <circle id="biz-sparkle-2" cx="48" cy="116" r="3" fill="#C6F542" fill-opacity="0.25"/>
  <circle id="biz-sparkle-3" cx="66" cy="118" r="2" fill="#C6F542" fill-opacity="0.2"/>

