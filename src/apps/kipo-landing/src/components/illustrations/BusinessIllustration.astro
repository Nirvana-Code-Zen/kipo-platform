---
// Dueño de negocio mostrando tablet con factura a cliente
---

<svg
  viewBox="0 0 440 320"
  width="100%"
  
  xmlns="http://www.w3.org/2000/svg"
  aria-labelledby="business-illus-title"
  role="img"
>
  <title id="business-illus-title">Dueño de negocio mexicano muestra factura en tablet a su cliente</title>

  <defs>
    <filter id="biz-drop" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="3" stdDeviation="5" flood-color="#032641" flood-opacity="0.10"/>
    </filter>
    <clipPath id="awning-clip">
      <rect x="0" y="0" width="440" height="320"/>
    </clipPath>
  </defs>

  <!-- === BACKGROUND / STOREFRONT === -->

  <!-- Sky / wall -->
  <rect x="0" y="0" width="440" height="320" fill="#FAF8FB"/>

  <!-- Wall texture / building -->
  <rect x="30" y="40" width="380" height="220" rx="12" fill="#f8f6f5"/>
  <!-- Wall grout lines subtle -->
  <line x1="30" y1="90" x2="410" y2="90" stroke="#E4D9C9" stroke-width="1"/>
  <line x1="30" y1="140" x2="410" y2="140" stroke="#E4D9C9" stroke-width="1"/>
  <line x1="30" y1="190" x2="410" y2="190" stroke="#E4D9C9" stroke-width="1"/>
  <line x1="140" y1="40" x2="140" y2="260" stroke="#E4D9C9" stroke-width="1"/>
  <line x1="230" y1="40" x2="230" y2="260" stroke="#E4D9C9" stroke-width="1"/>
  <line x1="320" y1="40" x2="320" y2="260" stroke="#E4D9C9" stroke-width="1"/>

  <!-- Storefront awning -->
  <rect x="20" y="40" width="400" height="44" rx="0" fill="#e00b26"/>
  <rect x="20" y="78" width="400" height="8" rx="0" fill="#bc0921"/>
  <!-- Awning scallop edge -->
  <path d="M20 86 Q40 100 60 86 Q80 100 100 86 Q120 100 140 86 Q160 100 180 86 Q200 100 220 86 Q240 100 260 86 Q280 100 300 86 Q320 100 340 86 Q360 100 380 86 Q400 100 420 86 L420 78 L20 78z" fill="#e00b26"/>
  <!-- Awning stripe lines -->
  <line x1="60" y1="40" x2="60" y2="78" stroke="#bc0921" stroke-width="1.5" opacity="0.5"/>
  <line x1="100" y1="40" x2="100" y2="78" stroke="#bc0921" stroke-width="1.5" opacity="0.5"/>
  <line x1="140" y1="40" x2="140" y2="78" stroke="#bc0921" stroke-width="1.5" opacity="0.5"/>
  <line x1="180" y1="40" x2="180" y2="78" stroke="#bc0921" stroke-width="1.5" opacity="0.5"/>
  <line x1="220" y1="40" x2="220" y2="78" stroke="#bc0921" stroke-width="1.5" opacity="0.5"/>
  <line x1="260" y1="40" x2="260" y2="78" stroke="#bc0921" stroke-width="1.5" opacity="0.5"/>
  <line x1="300" y1="40" x2="300" y2="78" stroke="#bc0921" stroke-width="1.5" opacity="0.5"/>
  <line x1="340" y1="40" x2="340" y2="78" stroke="#bc0921" stroke-width="1.5" opacity="0.5"/>
  <line x1="380" y1="40" x2="380" y2="78" stroke="#bc0921" stroke-width="1.5" opacity="0.5"/>

  <!-- Store sign -->
  <rect x="160" y="48" width="120" height="26" rx="6" fill="#FAF8FB" fill-opacity="0.92"/>
  <rect x="172" y="54" width="44" height="6" rx="3" fill="#e00b26" fill-opacity="0.8"/>
  <rect x="222" y="54" width="44" height="6" rx="3" fill="#032641" fill-opacity="0.6"/>
  <rect x="180" y="62" width="80" height="5" rx="2" fill="#A99E8C"/>

  <!-- Counter / display shelf -->
  <rect x="120" y="220" width="200" height="20" rx="8" fill="#C8BCA8"/>
  <rect x="120" y="220" width="200" height="6" rx="4" fill="#D4C9B8"/>
  <!-- Counter front panel -->
  <rect x="122" y="240" width="196" height="40" rx="6" fill="#E4D9C9"/>
  <!-- Counter front detail -->
  <rect x="135" y="250" width="40" height="4" rx="2" fill="#C8BCA8"/>
  <rect x="185" y="250" width="40" height="4" rx="2" fill="#C8BCA8"/>
  <rect x="265" y="250" width="40" height="4" rx="2" fill="#C8BCA8"/>

  <!-- Small product on counter -->
  <rect x="136" y="204" width="24" height="18" rx="4" fill="#FAF8FB"/>
  <rect x="138" y="206" width="20" height="12" rx="2" fill="#EAF6FD"/>
  <rect x="140" y="208" width="12" height="3" rx="1" fill="#C8BCA8"/>
  <rect x="140" y="213" width="8" height="2" rx="1" fill="#C8BCA8"/>

  <!-- Ground / floor -->
  <rect x="0" y="280" width="440" height="40" fill="#E4D9C9"/>
  <rect x="0" y="278" width="440" height="4" rx="0" fill="#C8BCA8"/>

  <!-- === OWNER CHARACTER (left, darker skin, red apron) === -->

  <!-- Legs -->
  <rect x="148" y="222" width="22" height="68" rx="8" fill="#032641"/>
  <rect x="174" y="222" width="22" height="68" rx="8" fill="#032641"/>
  <!-- Pant highlights -->
  <rect x="152" y="226" width="6" height="45" rx="3" fill="#032641" fill-opacity="0.4"/>
  <rect x="178" y="226" width="6" height="45" rx="3" fill="#032641" fill-opacity="0.4"/>
  <!-- Shoes -->
  <ellipse cx="159" cy="290" rx="16" ry="8" fill="#2C1810"/>
  <ellipse cx="185" cy="290" rx="16" ry="8" fill="#2C1810"/>

  <!-- Apron body (over torso) -->
  <rect x="144" y="162" width="56" height="70" rx="14" fill="#FAF8FB"/>
  <!-- Apron front -->
  <rect x="152" y="168" width="40" height="62" rx="8" fill="#f8f6f5"/>
  <!-- Apron top strap -->
  <rect x="156" y="163" width="30" height="8" rx="4" fill="#E4D9C9"/>
  <!-- Apron pocket -->
  <rect x="157" y="200" width="28" height="18" rx="5" fill="#E4D9C9"/>
  <rect x="159" y="202" width="24" height="14" rx="3" fill="#FAF8FB"/>

  <!-- Red shirt under apron (sleeves) -->
  <!-- Left sleeve -->
  <path d="M144 172 Q122 185 116 212" stroke="#e00b26" stroke-width="18" stroke-linecap="round" fill="none"/>
  <!-- Right sleeve (holding tablet) -->
  <path d="M200 172 Q222 185 224 205" stroke="#e00b26" stroke-width="18" stroke-linecap="round" fill="none"/>

  <!-- Left hand -->
  <ellipse cx="115" cy="216" rx="11" ry="9" fill="#9B6140"/>
  <!-- Right hand (holds tablet) -->
  <ellipse cx="226" cy="208" rx="10" ry="8" fill="#9B6140"/>

  <!-- Neck -->
  <rect x="160" y="152" width="22" height="18" rx="10" fill="#9B6140"/>

  <!-- Head -->
  <ellipse cx="171" cy="138" rx="30" ry="32" fill="#9B6140"/>
  <!-- Ear left -->
  <ellipse cx="142" cy="138" rx="6" ry="8" fill="#9B6140"/>
  <!-- Ear right -->
  <ellipse cx="200" cy="138" rx="6" ry="8" fill="#9B6140"/>

  <!-- Hair - short dark -->
  <ellipse cx="171" cy="114" rx="31" ry="16" fill="#2C1810"/>
  <path d="M141 128 Q143 110 171 108 Q199 110 201 128" fill="#2C1810"/>
  <!-- Hair fade sides -->
  <rect x="141" y="120" width="10" height="18" rx="5" fill="#2C1810"/>
  <rect x="191" y="120" width="10" height="18" rx="5" fill="#2C1810"/>

  <!-- Owner face -->
  <!-- Eyebrows -->
  <path d="M160 132 Q164 129 168 131" stroke="#2C1810" stroke-width="2" stroke-linecap="round" fill="none"/>
  <path d="M174 131 Q178 129 182 132" stroke="#2C1810" stroke-width="2" stroke-linecap="round" fill="none"/>
  <!-- Eyes -->
  <ellipse cx="164" cy="138" rx="5" ry="5.5" fill="#1A1A1A"/>
  <ellipse cx="178" cy="138" rx="5" ry="5.5" fill="#1A1A1A"/>
  <circle cx="166" cy="136" r="1.8" fill="white" fill-opacity="0.6"/>
  <circle cx="180" cy="136" r="1.8" fill="white" fill-opacity="0.6"/>
  <!-- Nose -->
  <ellipse cx="171" cy="146" rx="3.5" ry="2.5" fill="#855030" fill-opacity="0.6"/>
  <!-- Smile (warm/friendly) -->
  <path d="M163 152 Q171 158 179 152" stroke="#7A4020" stroke-width="1.8" fill="none" stroke-linecap="round"/>
  <!-- Mustache hint -->
  <path d="M164 149 Q167 151 171 150 Q175 151 178 149" stroke="#2C1810" stroke-width="1.5" fill="none" stroke-linecap="round" opacity="0.6"/>
  <!-- Cheek blush -->
  <ellipse cx="155" cy="144" rx="7" ry="4" fill="#C87840" fill-opacity="0.2"/>
  <ellipse cx="187" cy="144" rx="7" ry="4" fill="#C87840" fill-opacity="0.2"/>

  <!-- === TABLET (held between them) === -->
  <rect x="208" y="165" width="72" height="96" rx="10" fill="#032641" filter="url(#biz-drop)"/>
  <!-- Tablet screen -->
  <rect x="213" y="170" width="62" height="84" rx="7" fill="#F0F8FF"/>
  <!-- Tablet home button strip -->
  <rect x="232" y="258" width="24" height="5" rx="2" fill="#032641"/>

  <!-- Tablet screen content -->
  <!-- Header bar -->
  <rect x="213" y="170" width="62" height="14" rx="7" fill="#e00b26"/>
  <rect x="213" y="177" width="62" height="7" rx="0" fill="#e00b26"/>
  <!-- Header text placeholder -->
  <rect x="218" y="173" width="30" height="4" rx="2" fill="white" fill-opacity="0.7"/>

  <!-- Invoice preview on tablet -->
  <rect x="218" y="189" width="52" height="4" rx="2" fill="#2C1810" fill-opacity="0.7"/>
  <rect x="218" y="196" width="38" height="3" rx="1.5" fill="#A99E8C"/>
  <rect x="218" y="204" width="52" height="1" rx="0.5" fill="#E4D9C9"/>
  <rect x="218" y="208" width="24" height="4" rx="2" fill="#A99E8C"/>
  <!-- Amount highlight -->
  <rect x="218" y="215" width="52" height="8" rx="3" fill="#FEE2E5"/>
  <rect x="222" y="218" width="40" height="4" rx="2" fill="#e00b26" fill-opacity="0.7"/>
  <!-- Timbrada badge -->
  <rect x="218" y="228" width="52" height="14" rx="5" fill="#DCFCE7"/>
  <circle cx="228" cy="235" r="5" fill="#16A34A"/>
  <path d="M225.5 235l2 2 4-4" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  <rect x="236" y="232" width="28" height="3" rx="1.5" fill="#16A34A" fill-opacity="0.7"/>
  <rect x="236" y="237" width="20" height="3" rx="1.5" fill="#16A34A" fill-opacity="0.4"/>

  <!-- === CLIENT CHARACTER (right, lighter skin, lime-green top) === -->

  <!-- Legs -->
  <rect x="270" y="222" width="22" height="68" rx="8" fill="#3A4C5F"/>
  <rect x="296" y="222" width="22" height="68" rx="8" fill="#3A4C5F"/>
  <!-- Shoes -->
  <ellipse cx="281" cy="290" rx="16" ry="8" fill="#2C1810"/>
  <ellipse cx="307" cy="290" rx="16" ry="8" fill="#2C1810"/>

  <!-- Lime green top -->
  <rect x="258" y="162" width="72" height="70" rx="14" fill="#C6F542"/>
  <!-- Top shading -->
  <rect x="258" y="162" width="22" height="70" rx="12" fill="#A9D92B" fill-opacity="0.3"/>

  <!-- Left arm (pointing at tablet with interest) -->
  <path d="M258 175 Q238 188 230 208" stroke="#C6F542" stroke-width="16" stroke-linecap="round" fill="none"/>
  <path d="M258 175 Q238 188 230 208" stroke="#F9C8A0" stroke-width="12" stroke-linecap="round" fill="none"/>
  <!-- Left hand -->
  <ellipse cx="229" cy="212" rx="10" ry="8" fill="#F9C8A0"/>
  <!-- Pointing finger -->
  <ellipse cx="222" cy="208" rx="6" ry="4" fill="#F9C8A0"/>

  <!-- Right arm (down) -->
  <path d="M330 175 Q348 192 352 216" stroke="#C6F542" stroke-width="16" stroke-linecap="round" fill="none"/>
  <!-- Right hand -->
  <ellipse cx="353" cy="220" rx="10" ry="8" fill="#F9C8A0"/>

  <!-- Neck -->
  <rect x="282" y="152" width="20" height="18" rx="9" fill="#F9C8A0"/>

  <!-- Head -->
  <ellipse cx="292" cy="136" rx="30" ry="32" fill="#F9C8A0"/>
  <!-- Ear left -->
  <ellipse cx="262" cy="136" rx="6" ry="8" fill="#F9C8A0"/>
  <!-- Ear right -->
  <ellipse cx="322" cy="136" rx="6" ry="8" fill="#F9C8A0"/>

  <!-- Client hair - wavy longer hair -->
  <ellipse cx="292" cy="112" rx="32" ry="18" fill="#4A2C1A"/>
  <path d="M262 128 Q262 106 292 104 Q322 106 322 128" fill="#4A2C1A"/>
  <!-- Hair sides flowing down -->
  <path d="M262 128 Q258 145 262 162" stroke="#4A2C1A" stroke-width="12" stroke-linecap="round" fill="none"/>
  <path d="M322 128 Q326 145 322 162" stroke="#4A2C1A" stroke-width="12" stroke-linecap="round" fill="none"/>
  <!-- Hair highlight -->
  <ellipse cx="280" cy="108" rx="12" ry="6" fill="#6B3E22" fill-opacity="0.5"/>

  <!-- Client face -->
  <!-- Eyebrows -->
  <path d="M280 128 Q284 125 288 127" stroke="#4A2C1A" stroke-width="1.8" stroke-linecap="round" fill="none"/>
  <path d="M296 127 Q300 125 304 128" stroke="#4A2C1A" stroke-width="1.8" stroke-linecap="round" fill="none"/>
  <!-- Eyes (slightly wide, looking at tablet with interest) -->
  <ellipse cx="284" cy="135" rx="5.5" ry="6" fill="#1A1A1A"/>
  <ellipse cx="300" cy="135" rx="5.5" ry="6" fill="#1A1A1A"/>
  <circle cx="286" cy="133" r="2" fill="white" fill-opacity="0.65"/>
  <circle cx="302" cy="133" r="2" fill="white" fill-opacity="0.65"/>
  <!-- Nose -->
  <ellipse cx="292" cy="143" rx="3" ry="2" fill="#E8A88A" fill-opacity="0.7"/>
  <!-- Open-mouth smile (impressed) -->
  <path d="M284 151 Q292 158 300 151" stroke="#C07040" stroke-width="2" fill="none" stroke-linecap="round"/>
  <ellipse cx="292" cy="153" rx="5" ry="3" fill="#E88080" fill-opacity="0.3"/>
  <!-- Cheek blush -->
  <ellipse cx="272" cy="141" rx="7" ry="4" fill="#F0A080" fill-opacity="0.22"/>
  <ellipse cx="312" cy="141" rx="7" ry="4" fill="#F0A080" fill-opacity="0.22"/>

  <!-- === SPEECH BUBBLE from client side === -->
  <rect x="322" y="98" width="96" height="38" rx="12" fill="white" filter="url(#biz-drop)"/>
  <path d="M322 124 l-14 14 16-5z" fill="white"/>
  <rect x="322" y="98" width="96" height="38" rx="12" fill="none" stroke="#DCFCE7" stroke-width="1.5"/>
  <rect x="333" y="108" width="74" height="5" rx="2" fill="#032641" fill-opacity="0.5"/>
  <rect x="333" y="116" width="55" height="5" rx="2" fill="#16A34A" fill-opacity="0.7"/>
  <rect x="333" y="124" width="42" height="4" rx="2" fill="#A99E8C"/>

  <!-- Floating lime decorations -->
  <circle cx="58" cy="104" r="5" fill="#C6F542" fill-opacity="0.4"/>
  <circle cx="48" cy="116" r="3" fill="#C6F542" fill-opacity="0.25"/>
  <circle cx="66" cy="118" r="2" fill="#C6F542" fill-opacity="0.2"/>

</svg>
