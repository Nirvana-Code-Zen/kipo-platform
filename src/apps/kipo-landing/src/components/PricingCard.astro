---
interface Props {
  stamps: number
  price: string
  pricePerStamp: string
  featured?: boolean
  label?: string
  ctaLabel: string
  ctaHref: string
}

const { stamps, price, pricePerStamp, featured = false, label, ctaLabel, ctaHref } = Astro.props
---

<div
  class="relative flex flex-col rounded-kipo-lg border p-6 transition-shadow duration-200 hover:shadow-kipo-md"
  style={featured
    ? 'background-color: var(--surface-card); border-color: var(--kipo-red); box-shadow: 0 0 0 1px var(--kipo-red), var(--shadow-sm);'
    : 'background-color: var(--surface-card); border-color: var(--border-subtle);'}
>
  {label && (
    <div class="absolute -top-3 left-1/2 -translate-x-1/2">
      <span
        class="inline-block rounded-kipo-pill px-3 py-1 font-body text-xs font-semibold text-white"
        style="background-color: var(--kipo-red);"
      >
        {label}
      </span>
    </div>
  )}

  <div class="mb-4">
    <p class="font-body text-sm font-medium text-text-muted">
      {stamps} {stamps === 1 ? 'timbre' : 'timbres'}
    </p>
    <p
      class="font-display mt-1 font-extrabold text-text-strong"
      style="font-family: var(--font-display); font-size: 2rem; letter-spacing: -0.03em; line-height: 1;"
    >
      {price}
    </p>
    <p class="font-body mt-1 text-xs text-text-muted">{pricePerStamp}</p>
  </div>

  <a
    href={ctaHref}
    class="mt-auto inline-flex w-full items-center justify-center rounded-kipo px-4 py-2.5 font-body text-sm font-semibold transition-all duration-150 active:scale-[0.97]"
    style={featured
      ? 'background-color: var(--kipo-red); color: var(--text-on-brand);'
      : 'background-color: var(--bg-subtle); color: var(--text-strong);'}
  >
    {ctaLabel}
  </a>
</div>
