---
import Button from './Button.astro'
---

<section class="flex min-h-screen flex-col items-center justify-center px-6 text-center">
  <div class="max-w-4xl">
    <h1 class="font-urbanist text-5xl font-bold leading-tight text-brand-secondary md:text-6xl">
      Tu plataforma financiera,
      <span class="text-brand-primary">inteligente</span>
    </h1>

    <p class="mt-6 font-inter text-lg text-brand-secondary/70 md:text-xl">
      Gestiona tus finanzas con claridad. Kipo te da las herramientas para tomar mejores decisiones.
    </p>

    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <Button href="/app" variant="primary" size="lg">
        Empezar gratis
      </Button>
      <Button href="#features" variant="ghost" size="lg">
        Ver cómo funciona
      </Button>
    </div>
  </div>
</section>
