---
import {Image} from 'astro:assets'
import Button from './Button.astro'
import kipoLogo from '../assets/kipo-logo/kipo-logo.svg'

---

<header id="site-nav" class="fixed inset-x-0 top-0 z-50 transition-all duration-200">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">

    <a
      href="/"
      class="flex items-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
      aria-label="Kipo — inicio"
    >
      <Image src={kipoLogo} alt="Facturas en segundos. Sin drama. Logo" class="h-12 w-9 object-cover" aria-hidden="true" />
      <span
        class="text-xl font-bold tracking-tight text-text-strong-font-display"
      >Kipo</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Navegación principal" data-zone="desktop nav">
      <a href="/#como-funciona" class="font-body text-sm font-medium text-text-body transition-colors hover:text-text-strong">Cómo funciona</a>
      <a href="/#caracteristicas" class="font-body text-sm font-medium text-text-body transition-colors hover:text-text-strong">Características</a>
      <a href="/precios" class="font-body text-sm font-medium text-text-body transition-colors hover:text-text-strong">Precios</a>
    </nav>

    <div class="hidden items-center gap-3 md:flex" data-zone="desktop actions">
      <Button href="/login" variant="ghost" size="sm">Inicia sesión</Button>
      <Button href="/registro" variant="primary" size="sm">Empieza gratis</Button>
    </div>

    <div class="flex items-center gap-1 md:hidden">
      <button
        id="mobile-menu-btn"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-zone="mobile-menu"
        class="flex h-11 w-11 items-center justify-center rounded-kipo transition-colors hover:bg-bg-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
      >
        <svg class="hamburger-icon h-5 w-5 text-text-strong" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg class="close-icon hidden h-5 w-5 text-text-strong" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    aria-label="Mobile menu"
    class="hidden border-t border-border-subtle bg-surface-card px-6 py-4 md:hidden"
  >
    <nav class="flex flex-col gap-1" aria-label="Menú móvil">
      <a href="/#como-funciona" class="rounded-kipo px-3 py-3 font-body text-base font-medium text-text-body transition-colors hover:bg-bg-subtle">Cómo funciona</a>
      <a href="/#caracteristicas" class="rounded-kipo px-3 py-3 font-body text-base font-medium text-text-body transition-colors hover:bg-bg-subtle">Características</a>
      <a href="/precios" class="rounded-kipo px-3 py-3 font-body text-base font-medium text-text-body transition-colors hover:bg-bg-subtle">Precios</a>
      <div class="mt-3 flex flex-col gap-2 border-t border-border-subtle pt-3">
        <Button href="/login" variant="ghost" size="md" class="justify-start">Inicia sesión</Button>
        <Button href="/registro" variant="primary" size="md">Empieza gratis</Button>
      </div>
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  const onScroll = () => {
    if (window.scrollY > 20) {
      nav?.classList.add('nav-scrolled');
    } else {
      nav?.classList.remove('nav-scrolled');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  function setMenuOpen(open: boolean) {
    if (open) {
      mobileMenu?.classList.remove('hidden');
      mobileMenu?.classList.add('menu-open');
    } else {
      mobileMenu?.classList.remove('menu-open');
      mobileMenu?.classList.add('hidden');
    }
    menuBtn?.setAttribute('aria-expanded', String(open));
    menuBtn?.querySelector('.hamburger-icon')?.classList.toggle('hidden', open);
    menuBtn?.querySelector('.close-icon')?.classList.toggle('hidden', !open);
  }

  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    setMenuOpen(!isOpen);
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      setMenuOpen(false);
      menuBtn?.focus();
    });
  });
</script>
