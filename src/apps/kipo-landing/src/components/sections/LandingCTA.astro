---
import Button from '../Button.astro'
---

<div class="cta-float-wrap">
  <div class="cta-float-card mx-auto max-w-6xl w-full px-6" data-theme="dark">
    <div class="cta-left">
      <h2 class="cta-headline">
        Tu primera factura,<br />lista en 2 minutos.
      </h2>
      <div class="cta-badges">
        {[
          'RFC validado en tiempo real',
          'CFDI 4.0 válido ante el SAT',
          'PDF y XML oficiales incluidos',
        ].map((item, i) => (
          <span
            class="reveal cta-badge"
            style={`transition-delay: ${i * 70}ms;`}
          >
            <svg width="10" height="8" viewBox="0 0 10 8" fill="none" aria-hidden="true">
              <path d="M1 4l2.5 2.5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {item}
          </span>
        ))}
      </div>
    </div>

    <div class="cta-right">
      <Button href="/registro" variant="primary" size="lg">Empieza gratis</Button>
      <a
        href="/precios"
        class="cta-secondary-link"
      >
        Ver planes y precios →
      </a>
    </div>
  </div>
</div>

<style>
  .cta-float-wrap {
    padding: 0 1.5rem;
  }

  .cta-float-card {
    background-color: var(--kipo-slate-900);
    border-radius: 24px;
    padding: 4.75rem 3.5rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    align-items: center;
    box-shadow:
      0 8px 48px rgba(3, 38, 65, 0.18),
    0 2px 8px rgba(3, 38, 65, 0.1);
  }

  .cta-left {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cta-headline {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.8vw, 2.1rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.1;
    text-wrap: balance;
    color: var(--text-strong);
    margin: 0;
  }

  .cta-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .cta-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--kipo-cream-0) 16%, transparent);
    padding: 0.25rem 0.75rem;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-body);
  }

  .cta-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.875rem;
    flex-shrink: 0;
  }

  .cta-secondary-link {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 150ms;
    white-space: nowrap;
  }
  .cta-secondary-link:hover {
    color: var(--text-body);
  }

  @media (max-width: 640px) {
    .cta-float-card {
      grid-template-columns: 1fr;
      padding: 2rem 1.5rem;
      gap: 1.5rem;
      border-radius: 16px;
    }
    .cta-right {
      align-items: flex-start;
    }
    .cta-float-wrap {
      padding: 0 1rem;
    }
  }
</style>
