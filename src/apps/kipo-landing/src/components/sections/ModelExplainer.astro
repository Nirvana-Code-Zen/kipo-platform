---
---

<section class="border-b" style="background-color: var(--kipo-cream-0);">
  <div class="mx-auto max-w-4xl px-6 py-16">
    <div class="grid gap-12 sm:grid-cols-2">

      <div class="flex gap-5">
        <div
          class="flex h-11 w-11 shrink-0 items-center justify-center rounded-kipo-lg"
          style="background-color: var(--bg-subtle);"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--kipo-red)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
          </svg>
        </div>
        <div>
          <p class="font-body mb-1 text-xs font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Timbres</p>
          <p class="font-display mb-2 text-lg font-bold" style="font-family: var(--font-display); color: var(--text-strong);">Pagas cuando facturas</p>
          <p class="font-body text-sm leading-relaxed" style="color: var(--text-body); max-width: 36ch; text-wrap: pretty;">
            Compra el paquete que necesites. Desde $5.80 por timbre. Los timbres no vencen
            y funcionan con cualquier plan.
          </p>
        </div>
      </div>

      <div class="flex gap-5">
        <div
          class="flex h-11 w-11 shrink-0 items-center justify-center rounded-kipo-lg"
          style="background-color: var(--bg-subtle);"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--kipo-red)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="3" />
            <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14" />
            <path d="M15.54 8.46a5 5 0 0 1 0 7.07M8.46 8.46a5 5 0 0 0 0 7.07" />
          </svg>
        </div>
        <div>
          <p class="font-body mb-1 text-xs font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Herramientas</p>
          <p class="font-display mb-2 text-lg font-bold" style="font-family: var(--font-display); color: var(--text-strong);">Suscripción opcional</p>
          <p class="font-body text-sm leading-relaxed" style="color: var(--text-body); max-width: 36ch; text-wrap: pretty;">
            Automatización fiscal, alertas del SAT, facturas recurrentes y más.
            Solo cuando las necesitas. Tus timbres siempre son tuyos.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
