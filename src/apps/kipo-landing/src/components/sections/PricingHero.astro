---
import Button from '../Button.astro'
---

<div class="pricing-hero-inner text-center">
  <div class="mx-auto max-w-2xl px-6">
    <h1
      class="font-display mb-5 text-3xl font-bold sm:text-4xl md:text-5xl"
      style="font-family: var(--font-display); letter-spacing: -0.03em; text-wrap: balance; color: var(--text-strong); line-height: 1.05;"
    >
      14 días gratis.<br />Después, solo pagas lo que usas.
    </h1>
    <p
      class="font-body mb-8 text-lg"
      style="color: var(--text-body); max-width: 42ch; margin-left: auto; margin-right: auto; text-wrap: pretty;"
    >
      Acceso completo al Plan Emprendedor — automatización fiscal, alertas SAT y facturas
      recurrentes — sin tarjeta y sin compromiso.
    </p>

    <Button href="/registro?trial=emprendedor" variant="primary" size="lg">
      Empezar prueba gratis
    </Button>

    <div class="mt-5 flex flex-wrap items-center justify-center gap-x-4 gap-y-1">
      {['Cancela cuando quieras', 'Timbres nunca vencen'].map((item) => (
        <span class="font-body text-xs" style="color: var(--text-muted);">{item}</span>
      ))}
    </div>
  </div>
</div>

<style>
  .pricing-hero-inner {
    padding: 2rem 1.5rem;
  }
</style>
