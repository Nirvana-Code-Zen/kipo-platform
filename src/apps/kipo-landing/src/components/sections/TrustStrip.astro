---
---

<section style="background-color: var(--bg-base); border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle);">
  <div class="mx-auto max-w-6xl px-6 py-8">
    <p class="mb-6 text-center font-body text-xs font-semibold uppercase tracking-widest text-text-muted">
      Tecnología certificada
    </p>
    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-16">

      <div class="flex items-center gap-2">
        <div class="flex h-8 w-8 items-center justify-center rounded-full" style="background: var(--kipo-gradient);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <div>
          <div class="font-body text-sm font-bold text-text-strong">SAT</div>
          <div class="font-body text-xs text-text-muted">Autorizado</div>
        </div>
      </div>

      <div class="hidden h-8 w-px bg-border-subtle md:block"></div>

      <div class="flex items-center gap-2">
        <div class="flex h-8 w-8 items-center justify-center rounded-kipo bg-bg-subtle">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
        </div>
        <div>
          <div class="font-body text-sm font-bold text-text-strong">CFDI 4.0</div>
          <div class="font-body text-xs text-text-muted">Versión vigente</div>
        </div>
      </div>

      <div class="hidden h-8 w-px bg-border-subtle md:block"></div>

      <div class="flex items-center gap-2">
        <div class="flex h-8 w-8 items-center justify-center rounded-kipo" style="background-color: #0EA5E9;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
          </svg>
        </div>
        <div>
          <a href="https://www.facturapi.io" target="_blank" rel="noopener noreferrer" class="font-body text-sm font-bold" style="color: #0EA5E9;">FacturAPI</a>
          <div class="font-body text-xs text-text-muted">PAC certificado</div>
        </div>
      </div>

      <div class="hidden h-8 w-px bg-border-subtle md:block"></div>

      <div class="flex items-center gap-2">
        <div class="flex h-8 w-8 items-center justify-center rounded-kipo bg-bg-subtle">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted" aria-hidden="true">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
          </svg>
        </div>
        <div>
          <div class="font-body text-sm font-bold text-text-strong">Timbrado</div>
          <div class="font-body text-xs text-text-muted">En segundos</div>
        </div>
      </div>

    </div>
  </div>
</section>
