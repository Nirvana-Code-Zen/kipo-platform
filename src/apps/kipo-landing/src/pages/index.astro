---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/Hero.astro'
---

<Layout title="Kipo — Tu plataforma financiera">
  <main>
    <Hero />

    <section id="features" class="px-6 py-24">
      <div class="mx-auto max-w-5xl">
        <h2 class="font-lato text-3xl font-bold text-brand-secondary">
          Todo lo que necesitas
        </h2>
        <p class="mt-4 font-inter text-brand-secondary/70">
          Más funcionalidades próximamente.
        </p>
      </div>
    </section>
  </main>
</Layout>
